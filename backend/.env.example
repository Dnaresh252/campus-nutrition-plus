# Database - use DATABASE_URL for Render/Railway, or individual vars for local
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_nutrition
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development
TZ=Asia/Kolkata

# CORS - set these to your deployed frontend URLs
FRONTEND_URL=https://your-frontend.vercel.app
ADMIN_URL=https://your-admin.vercel.app
